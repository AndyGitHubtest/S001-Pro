# S001-Pro Monitor 配置文件
# 复制为 .env 并修改

# 安全密钥 (生产环境必须修改!)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库路径 (指向S001-Pro的数据库)
DATABASE_URL=sqlite:///~/S001-Pro/data/klines.db

# 监控面板数据库 (用户、配置等)
MONITOR_DB_URL=sqlite:///./data/monitor.db

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Binance API (只读，用于查询价格)
# 不需要交易权限，只需要读取行情
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 服务器配置
HOST=0.0.0.0
PORT=3000
DEBUG=false

# 缓存时间 (秒)
CACHE_TTL=5

# 日志级别
LOG_LEVEL=INFO
